<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.madapp">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/sheep_money_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/sheep_money_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.MadApp"
        tools:targetApi="31">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MadApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MadApp">
        </activity>
        <activity
            android:name=".AddIndividualExpenseActivity"
            android:exported="false" />
        <activity
            android:name=".GroupDetailsActivity"
            android:exported="false"
            android:label="Group Details"
            android:theme="@style/Theme.MadApp"
            android:parentActivityName=".MainActivity" />
    </application>

</manifest>